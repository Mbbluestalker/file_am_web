# FileAm Enterprise Web — environment variables template.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is committed.
# Browser-exposed vars MUST be prefixed with VITE_ (Vite only bundles those).

# Main enterprise backend — JWT-authenticated API used by every service call.
VITE_API_BASE_URL=https://api-v2.fileam.app

# AI backend — powers TaxGPT chat and invoice extraction (separate service).
VITE_AI_API_BASE_URL=https://api.ai.fileam.app
